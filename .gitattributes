# Force LF line endings for all text files in this repo.
# Prevents Windows editors from silently introducing CRLF into shell scripts,
# autotools files, and C source — all of which break on Linux when CRLF is present.
* text=auto eol=lf

# Explicitly mark binary formats so git never line-ending-converts them
*.p12   binary
*.pem   binary
*.der   binary
*.so    binary
*.la    binary
*.a     binary
